{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.21/MicrosoftTeams.schema.json",
  "manifestVersion": "1.21",
  "version": "0.1.0",
  "id": "{{TEAMS_APP_ID}}",
  "developer": {
    "name": "Plutonix MSP",
    "websiteUrl": "{{FRONTEND_BASE_URL}}",
    "privacyUrl": "{{FRONTEND_BASE_URL}}/privacy.html",
    "termsOfUseUrl": "{{FRONTEND_BASE_URL}}/terms.html"
  },
  "name": {
    "short": "M365 Onboarding",
    "full": "Microsoft 365 User Onboarding"
  },
  "description": {
    "short": "Submit Microsoft 365 onboarding requests.",
    "full": "A lightweight Teams tab for submitting Microsoft 365 user onboarding requests into a tenant-local Azure Functions workflow."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#27324A",
  "staticTabs": [
    {
      "entityId": "onboarding",
      "name": "Onboarding",
      "contentUrl": "{{FRONTEND_BASE_URL}}/",
      "websiteUrl": "{{FRONTEND_BASE_URL}}/",
      "scopes": ["personal"]
    }
  ],
  "validDomains": ["{{FRONTEND_DOMAIN}}"],
  "authorization": {
    "permissions": {
      "resourceSpecific": []
    }
  }
}
